# ==== Supabase (lấy từ Dashboard > Project Settings > API) ====
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key - DÙNG CHO WEBHOOK (Settings > API > service_role).
# TUYỆT ĐỐI không đặt tiền tố NEXT_PUBLIC_ (bí mật, chỉ chạy phía server).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==== Site ====
NEXT_PUBLIC_SITE_URL=https://nguonnhaphohcm.vn

# ==== SePay (thanh toán / nâng cấp gói) ====
# API key bạn tự tạo khi cấu hình Webhook trên my.sepay.vn > Webhooks.
# Dùng để xác thực request webhook gửi tới /api/sepay/webhook
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-api-key

# Thông tin tài khoản ngân hàng để tạo mã QR chuyển khoản.
# bank: mã ngân hàng theo SePay (VD: VCB, ACB, MB, TPB, VPB...).
NEXT_PUBLIC_SEPAY_BANK=VCB
NEXT_PUBLIC_SEPAY_ACCOUNT=0123456789
NEXT_PUBLIC_SEPAY_ACCOUNT_NAME=NGUYEN VAN A

# Google Maps Embed API key (Console > APIs > Maps Embed API). Dung cho ban do vi tri tin dang.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
